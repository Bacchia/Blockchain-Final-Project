# Arc Testnet (the only testnet Hinkal supports). Demo values point at the
# live deployment described in the README.
VITE_CHAIN_ID=5042002
VITE_EXPLORER_BASE=https://testnet.arcscan.app

# Demo mode: simulate Hinkal's shielding step (gated by a one-time KYC access
# token) while keeping the vote + tally real on-chain. Set to false to use the
# real Hinkal shielded path (requires a valid Hinkal access token).
VITE_DEMO_MODE=true

VITE_RPC_URL=https://rpc.testnet.arc.network
VITE_BALLOT_TOKEN_ADDRESS=0xDD7524D3fa066Eb1683F4279E829F2A14799e0EE
VITE_ELECTION_ADDRESS=0xb49ED152C58D2e782f4BA217AB64644432AD2279

# Fallback candidates (used only if the on-chain list can't be read). The app
# normally loads candidates + live tally from the Election contract above.
VITE_CANDIDATE_A=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
VITE_CANDIDATE_B=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC
VITE_CANDIDATE_C=0x90F79bf6EB2c4f870365E785982E1f101E93b906
