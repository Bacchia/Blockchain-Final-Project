# Arc Testnet is the primary target (the only testnet Hinkal supports).
# Gas on Arc is paid in test USDC — fund the deployer at faucet.circle.com.
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Optional: kept for reference, but Hinkal is NOT deployed on Sepolia.
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# A burner wallet's private key (testnet only — never use a real-funds key).
DEPLOYER_PRIVATE_KEY=0xyour_private_key_for_a_burner_wallet
ETHERSCAN_API_KEY=

# Candidate addresses (3 DISTINCT addresses). Leave blank to default to the
# deployer (only works for one candidate).
CANDIDATE_A=
CANDIDATE_B=
CANDIDATE_C=

# Voter addresses to issue 1 BALLOT each, comma-separated. Blank = deployer.
VOTERS=
